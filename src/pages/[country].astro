---
import Base from '../layouts/Base.astro';
import MatchCard from '../components/MatchCard.astro';
import BroadcasterTable from '../components/BroadcasterTable.astro';
import { SITE } from '../../site.config';
import {
  focusCountries,
  codeFromSlug,
  countrySlug,
  getCountry,
  teamFixtures,
  type Fixture,
} from '../lib/data';
import { longDate, kickoffBlock, cap } from '../lib/time';
import { breadcrumb, faqPage } from '../lib/schema';

export function getStaticPaths() {
  return focusCountries.map(({ code, data }) => ({
    params: { country: countrySlug(code) },
    props: { code, name: data.name },
  }));
}

interface Props { code: string; name: string; }
const { code, name } = Astro.props;
const country = getCountry(code)!;
const seleccion = teamFixtures(code) as Fixture[];
const hasTeam = seleccion.length > 0;
const next = seleccion[0];

const title = `Partidos de Hoy en ${name}: Horarios y Dónde Ver | Fútbol Hoy`;
const description = `Partidos de hoy en ${name}: a qué hora juegan, en qué canal y dónde ver el fútbol y el Mundial 2026 en vivo con los canales oficiales de ${name}.`;

const schema = [
  breadcrumb([
    { name: 'Inicio', url: `${SITE.url}/` },
    { name: `Partidos en ${name}` },
  ]),
  faqPage([
    {
      q: hasTeam ? `¿A qué hora juega ${name} hoy?` : `¿Dónde ver fútbol hoy en ${name}?`,
      a: hasTeam && next
        ? `El próximo partido de ${name} es ${next.teamA} vs ${next.teamB}, el ${longDate(next.date)}. Horarios: ${kickoffBlock(next.date)}.`
        : `En ${name} puedes ver los partidos por: ${country.broadcasters.map((b) => b.name).join(', ')}.`,
    },
    {
      q: `¿Qué canal transmite el fútbol en ${name}?`,
      a: `Los canales oficiales en ${name} son: ${country.broadcasters
        .map((b) => `${b.name} (${b.access === 'free' ? 'gratis' : 'pago'})`)
        .join(', ')}.`,
    },
  ]),
];
---
<Base title={title} description={description} schema={schema}>
  <nav class="crumbs"><a href="/">Inicio</a> › Partidos en {name}</nav>
  <h1>Partidos de Hoy en {name} — Horarios y Dónde Ver</h1>
  <p class="lead">
    <strong>Partidos de hoy en {name}</strong>: a qué hora juegan, en qué canal y dónde
    ver el fútbol y el Mundial 2026 en vivo con los canales oficiales de {name}.
  </p>

  <h2>Dónde ver fútbol en {name}</h2>
  <BroadcasterTable only={[code]} />
  <p>
    {country.broadcasters.some((b) => b.access === 'free')
      ? `En ${name} hay opción gratuita en señal abierta, además de las plataformas de pago para ver todos los partidos.`
      : `En ${name} la transmisión es principalmente por plataformas de pago como Disney+/ESPN y DGO.`}
  </p>

  {hasTeam ? (
    <section>
      <h2>Próximos partidos de {name} en el Mundial 2026</h2>
      <ul class="matches">
        {seleccion.map((f) => <MatchCard fixture={f} showDate />)}
      </ul>
      {next && (
        <p class="kickoff" style="margin-top:8px">
          Próximo: <strong>{next.teamA} vs {next.teamB}</strong> — {cap(longDate(next.date))}.
          Horarios: {kickoffBlock(next.date)}.
        </p>
      )}
    </section>
  ) : (
    <p class="note">
      La selección de {name} no figura en este cuadro de partidos, pero aquí tienes los
      canales oficiales para ver el resto del Mundial 2026 en {name}.
    </p>
  )}

  <h2>A qué hora juegan hoy en {name}</h2>
  <p>
    Los horarios del Mundial 2026 dependen del huso horario de {name}, ya que el torneo
    se juega en Estados Unidos, México y Canadá. En cada ficha de partido mostramos la
    hora local convertida para que no tengas que calcularla.
  </p>

  <p style="margin-top:24px">
    Mira todos los <a href="/">partidos de hoy</a>, el
    <a href="/mundial">calendario del Mundial</a> o la guía de
    <a href="/como-ver">cómo ver fútbol</a>.
  </p>
</Base>
